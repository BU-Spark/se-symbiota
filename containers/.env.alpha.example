# Symbiota Production Environment Configuration
#
# Copy this file to .env.prod and update with actual values
# cp .env.prod.example .env.prod
#
# SECURITY: Never commit .env.prod to git!

# ============================================================================
# Container Image Configuration
# ============================================================================

# Quay.io registry and image tag
QUAY_REGISTRY=quay.io/langdon/se-symbiota
IMAGE_TAG=v3.2.4-alpha

# Alternative: Use specific SHA for reproducible deployments
# IMAGE_TAG=v3.2.4-alpha-a1b2c3d

# ============================================================================
# Network Ports
# ============================================================================

# Host Port Mappings (external access)
# Format: HOST_PORT:CONTAINER_PORT
# - HTTP_PORT: External port on VM (OpenStack routes :80 → :8080 → container :80)
# - MYSQL_PORT: Removed - not exposed externally in production
HTTP_PORT=8080

# Application Connection Settings (internal container network)
# Used by PHP application to connect to services
MYSQL_HOST=symbiota-db
MYSQL_PORT=3306
OCR_HOST=ocr-middleware
OCR_PORT=8000

# ============================================================================
# Data Directory Configuration
# ============================================================================

# Alpha environment data (separate from integration)
DATA_DIR=/mnt/symbiota/data/alpha

# Individual data directories (derived from DATA_DIR if not specified)
# IMAGES_DIR=/mnt/symbiota/data/alpha/imglib
# LOGS_DIR=/mnt/symbiota/data/alpha/logs
# MYSQL_DATA_DIR=/mnt/symbiota/data/alpha/mysql

# ============================================================================
# Configuration Overlay
# ============================================================================

# Directory containing se-symbiota-private config files
# This directory structure will be overlaid onto the Symbiota code at container startup
# Keeps secrets out of the public Docker image
#
# Expected structure:
#   /mnt/symbiota/app/config/alpha/
#   ├── config/
#   │   ├── dbconnection.php    (database credentials)
#   │   └── symbini.php         (main config)
#   ├── content/                (site content and skin)
#   ├── includes/               (custom headers)
#   ├── header.php              (root customizations)
#   ├── footer.php
#   ├── leftmenu.php
#   └── index.php
#
# This is on the OpenStack /mnt/symbiota/app volume (persistent storage)
CONFIG_OVERLAY_DIR=/mnt/symbiota/app/config/alpha

# ============================================================================
# Database Credentials
# ============================================================================

# MySQL root password
MYSQL_ROOT_PASSWORD=CHANGEME_ROOT_PASSWORD

# Symbiota database name
MYSQL_DATABASE=symbiota

# Symbiota database user
MYSQL_USER=symbiota_rw

# Symbiota database password
MYSQL_PASSWORD=CHANGEME_SYMBIOTA_PASSWORD

# ============================================================================
# Apache Configuration
# ============================================================================

# Apache log level (debug, info, notice, warn, error, crit, alert, emerg)
APACHE_LOG_LEVEL=warn

# ============================================================================
# Optional: Schema/Backup Configuration
# ============================================================================

# Uncomment to mount schema/backup files
# SCHEMA_SOURCE=/mnt/symbiota/app/schema
