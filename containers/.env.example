# Symbiota Container Configuration
# Copy this file to .env and adjust paths for your environment

# ==============================================================================
# PATH CONFIGURATION
# ==============================================================================

# Path to Symbiota code (relative to this containers/ directory)
# Manual setup: Usually ../.. to get to the worktree root
# Bootstrap setup: .. (one level up from containers/)
PROJECT_ROOT=../..

# Path to Symbiota data directories (relative to this containers/ directory)
# These allow you to store large datasets on separate filesystems
# Leave empty to use directories within the code mount
# Bootstrap setup creates: ../../data/content and ../../data/logs
CONTENT_DIR=
LOGS_DIR=

# Deprecated: Use CONTENT_DIR instead
# Path to Symbiota data directory (images, specimens, etc.)
SYMBIOTA_DATA=

# Path to instance-specific config files
# Used to overlay config files onto Symbiota codebase
# Bootstrap setup creates: ../../config
CONFIG_DIR=../../config

# Path to database schema/backup files (optional)
# Used to import initial database or backups
SCHEMA_SOURCE=../../config/schema

# ==============================================================================
# MYSQL CONFIGURATION
# ==============================================================================

MYSQL_ROOT_PASSWORD=password
MYSQL_DATABASE=symbiota
MYSQL_USER=symbiota-user
MYSQL_PASSWORD=symbiota-pass

# MySQL data directory
# Default: Uses Docker named volume "mysql-data"
# For separate filesystem: Set to absolute path (e.g., /mnt/data/mysql)
MYSQL_DATA_DIR=mysql-data

# ==============================================================================
# PORT CONFIGURATION
# ==============================================================================

# HTTP port for Symbiota web interface
# Dev: Use non-standard port like 8080 to avoid conflicts
# Prod: Usually 80 or 443
HTTP_PORT=8080

# MySQL port
# Dev: Use non-standard port like 33060 to avoid conflicts
# Prod: Usually 3306
MYSQL_PORT=33060

# ==============================================================================
# COMPOSE CONFIGURATION
# ==============================================================================

# Which compose file to use
# Options: docker-compose.dev.yaml, docker-compose.prod.yaml
COMPOSE_FILE=docker-compose.dev.yaml

# Container runtime (docker-compose or podman-compose)
COMPOSE=docker-compose

# SELinux volume flags (for Fedora/RHEL/CentOS/Alma Linux)
# Set to ":z" for SELinux systems, leave empty for others
# Examples:
#   Fedora/RHEL/Alma: SELINUX_FLAG=:z
#   Ubuntu/Debian:    SELINUX_FLAG=
SELINUX_FLAG=
