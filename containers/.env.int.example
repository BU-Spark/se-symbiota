# Symbiota Integration Environment Configuration
#
# Copy this file to .env.int and update with actual values
# cp .env.int.example .env.int
#
# This environment is for developer integration testing
# Deployed from v3.2.4-all-features branch

# ============================================================================
# Container Image Configuration
# ============================================================================

# For integration, you can use locally built images or Quay
# Option 1: Local build (comment out image, uncomment build in compose)
# Option 2: Pull from Quay integration tag
QUAY_REGISTRY=quay.io/langdon/se-symbiota
IMAGE_TAG=v3.2.4-integration

# ============================================================================
# Network Ports
# ============================================================================

# Use different ports to avoid conflicts with alpha
# Containers listen on :80 internally, podman maps to high ports on host
# OpenStack routes external :8080 → VM :9080 → container :80
HTTP_PORT=9080
MYSQL_PORT=33070

# ============================================================================
# Data Directory Configuration
# ============================================================================

# Integration environment data (separate from alpha)
DATA_DIR=/mnt/symbiota/data/int

# ============================================================================
# Configuration Overlay
# ============================================================================

# Directory containing se-symbiota-private config files for integration
# This directory structure will be overlaid onto the Symbiota code at container startup
# This is on the OpenStack /mnt/symbiota/app volume (persistent storage)
CONFIG_OVERLAY_DIR=/mnt/symbiota/app/config/int

# ============================================================================
# Database Credentials
# ============================================================================

MYSQL_ROOT_PASSWORD=CHANGEME_INT_ROOT_PASSWORD
MYSQL_DATABASE=symbiota_int
MYSQL_USER=symbiota_int
MYSQL_PASSWORD=CHANGEME_INT_PASSWORD

# ============================================================================
# Apache Configuration
# ============================================================================

APACHE_LOG_LEVEL=info
