# Symbiota Production Environment Configuration
#
# Copy this file to .env.prod and update with actual values
# cp .env.prod.example .env.prod
#
# SECURITY: Never commit .env.prod to git!

# ============================================================================
# Container Image Configuration
# ============================================================================

# Quay.io registry and image tag
QUAY_REGISTRY=quay.io/bu-spark/symbiota
IMAGE_TAG=alpha

# Alternative: Use specific SHA for reproducible deployments
# IMAGE_TAG=alpha-a1b2c3d

# ============================================================================
# Network Ports
# ============================================================================

HTTP_PORT=80
MYSQL_PORT=3306

# ============================================================================
# Data Directory Configuration
# ============================================================================

# Base data directory (matches /mnt/symbiota structure on server)
DATA_DIR=/mnt/symbiota/data

# Individual data directories (derived from DATA_DIR if not specified)
# IMAGES_DIR=/mnt/symbiota/data/imglib
# LOGS_DIR=/mnt/symbiota/data/logs
# MYSQL_DATA_DIR=/mnt/symbiota/data/mysql

# ============================================================================
# Configuration File
# ============================================================================

# Symbiota config file (from se-symbiota-private)
# This is mounted at runtime to keep secrets out of the image
CONFIG_FILE=/mnt/symbiota/app/config/symbini.php

# ============================================================================
# Database Credentials
# ============================================================================

# MySQL root password
MYSQL_ROOT_PASSWORD=CHANGEME_ROOT_PASSWORD

# Symbiota database name
MYSQL_DATABASE=symbiota

# Symbiota database user
MYSQL_USER=symbiota_rw

# Symbiota database password
MYSQL_PASSWORD=CHANGEME_SYMBIOTA_PASSWORD

# ============================================================================
# Apache Configuration
# ============================================================================

# Apache log level (debug, info, notice, warn, error, crit, alert, emerg)
APACHE_LOG_LEVEL=warn

# ============================================================================
# Optional: Schema/Backup Configuration
# ============================================================================

# Uncomment to mount schema/backup files
# SCHEMA_SOURCE=/mnt/symbiota/app/schema
