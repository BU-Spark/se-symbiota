# Git files (never bake VCS history/metadata into the published image)
.git
.git/**
**/.git
.gitignore
.gitattributes
.github/

# Documentation
*.md
README*
LICENSE*
CHANGELOG*
docs/
documentation/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Container development/build files — none of this belongs in the app image.
# The whole containers/ tree (compose files, Dockerfiles, bootstrap scripts,
# systemd units, env examples) is build tooling, not application code.
containers/
docker/
.dockerignore

# Secrets and any local env files — must never be copied into the image.
# (Config is overlaid at runtime via the read-only /config-overlay mount.)
.env
.env.*
**/.env
**/.env.*
*.pem
*.key
secrets/
.secrets/

# Runtime data directories (will be mounted at runtime)
temp/*
content/logs/*
content/imglib/*
content/dwca/*
!temp/.gitkeep
!content/logs/.gitkeep
!content/imglib/.gitkeep

# Node modules (if any)
node_modules/

# Local development files
*.local
.env
.env.*

# Test files
test/
tests/
*.test.php

# Backup files
*.bak
*.backup
*~

# Archive directories
archive/
backups/
