{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            // The name that appears in the VS Code debug dropdown
            "name": "Listen for Xdebug - PHP Symbiota",
            // The debugger type — must be "php" when using the PHP Debug extension
            "type": "php",
            // "launch" means VS Code will listen for incoming Xdebug connections
            "request": "launch",
            // The port Xdebug will connect to (default for Xdebug 3 is 9003)
            "port": 9003,
            // Enables debug logging in the VS Code OUTPUT → PHP Debug panel
            "log": true,
            "pathMappings": {
                /*
                This maps the path inside your Docker container
                to the matching path on your local machine.
                LEFT side:  Path as seen inside the container (from docker-compose)
                            /var/www/html/symbiota
                RIGHT side: Absolute path on your host where the same code lives.
                            Make sure this exactly matches your local folder path.
                */
                "/var/www/html/symbiota": "/Users/alanlin/Desktop/Symbiota/se-symbiota"
            }
        },
        {
            "name": "Listen for Xdebug",
            "type": "php",
            "request": "launch",
            "port": 9003
        },
        {
            "name": "Launch currently open script",
            "type": "php",
            "request": "launch",
            "program": "${file}",
            "cwd": "${fileDirname}",
            "port": 0,
            "runtimeArgs": [
                "-dxdebug.start_with_request=yes"
            ],
            "env": {
                "XDEBUG_MODE": "debug,develop",
                "XDEBUG_CONFIG": "client_port=${port}"
            }
        },
        {
            "name": "Launch Built-in web server",
            "type": "php",
            "request": "launch",
            "runtimeArgs": [
                "-dxdebug.mode=debug",
                "-dxdebug.start_with_request=yes",
                "-S",
                "localhost:0"
            ],
            "program": "",
            "cwd": "${workspaceRoot}",
            "port": 9003,
            "serverReadyAction": {
                "pattern": "Development Server \\(http://localhost:([0-9]+)\\) started",
                "uriFormat": "http://localhost:%s",
                "action": "openExternally"
            }
        }
    ]
}